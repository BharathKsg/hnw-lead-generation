# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_api_key
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Search ────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_key

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=hnw_leads
MONGO_COLLECTION=leads

# ── Target Location ───────────────────────────────────────────────────────────
TARGET_CITY=Bangalore
TARGET_STATE=Karnataka
TARGET_STATE_CODE=KA
TARGET_COUNTRY=India

# ── Pipeline Thresholds ───────────────────────────────────────────────────────
MIN_HNW_SCORE=60
MIN_NET_WORTH_MILLION=5
MAX_LEADS_PER_RUN=150
REQUEST_DELAY_SECONDS=1.5

# ── Threading ─────────────────────────────────────────────────────────────────
SCRAPE_THREADS=5        # parallel URL scrapers
ANALYSIS_THREADS=5      # parallel LLM chunk analysers

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=10000
CHUNK_OVERLAP=500
